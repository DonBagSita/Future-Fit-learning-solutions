# Future Fit AI Configuration
# Copy this to .env and fill in your values

# The URL of your backend API proxy
# For local development: http://localhost:3001/api/chat
# For production: https://your-vercel-project.vercel.app/api/chat
VITE_AI_API_URL=http://localhost:3001/api/chat

# Only used by server.mjs (local dev server) — NOT by the frontend
ANTHROPIC_API_KEY=sk-ant-your-key-here
